diff --git a/inference/marian-fork/src/3rd_party/ruy/third_party/cpuinfo/CMakeLists.txt b/inference/marian-fork/src/3rd_party/ruy/third_party/cpuinfo/CMakeLists.txt
index e2d7d53..6a77574 100644
--- a/inference/marian-fork/src/3rd_party/ruy/third_party/cpuinfo/CMakeLists.txt
+++ b/inference/marian-fork/src/3rd_party/ruy/third_party/cpuinfo/CMakeLists.txt
@@ -160,7 +160,12 @@ IF(CPUINFO_SUPPORTED_PLATFORM)
       ELSEIF(CMAKE_SYSTEM_PROCESSOR MATCHES "^(aarch64|arm64)$")
         LIST(APPEND CPUINFO_SRCS src/arm/linux/aarch64-isa.c)
       ENDIF()
-    ELSEIF(IOS OR (CMAKE_SYSTEM_NAME STREQUAL "Darwin" AND CPUINFO_TARGET_PROCESSOR STREQUAL "arm64"))
+    ELSEIF(IOS OR CMAKE_SYSTEM_NAME STREQUAL "iOS" OR (CMAKE_SYSTEM_NAME STREQUAL "Darwin" AND CPUINFO_TARGET_PROCESSOR STREQUAL "arm64"))
+      # The bare IOS variable is only set by an iOS *toolchain file*; translate-kit
+      # configures iOS via CMAKE_SYSTEM_NAME=iOS instead, so match that too (as the
+      # x86 mach branch above and the topology branch below already do). Without
+      # this, src/arm/mach/init.c is skipped and cpuinfo_arm_mach_init / cpuinfo_isa
+      # are undefined at link (ruy's CpuInfo::NeonDotprod references them).
       LIST(APPEND CPUINFO_SRCS src/arm/mach/init.c)
     ENDIF()
     IF(CMAKE_SYSTEM_NAME STREQUAL "Android")
